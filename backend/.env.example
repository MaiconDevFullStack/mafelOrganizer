# Ambiente
NODE_ENV=production
PORT=3000

# ── Banco de dados ────────────────────────────────────────────────────────────
# Railway injeta DATABASE_URL automaticamente via plugin PostgreSQL.
# Se preferir variáveis individuais, preencha abaixo (e remova DATABASE_URL):
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DB?sslmode=require

# Alternativa (variáveis individuais):
# DB_HOST=seu-host.railway.app
# DB_PORT=5432
# DB_NAME=railway
# DB_USER=postgres
# DB_PASS=sua_senha
# DB_SSL=true

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=troque_por_segredo_forte_com_32_chars_ou_mais
JWT_EXPIRATION=8h

# ── Redis  (Railway: adicionar plugin Redis) ──────────────────────────────────
REDIS_URL=redis://default:senha@host.railway.app:6379
# Alternativa individual:
# REDIS_HOST=seu-redis.railway.app
# REDIS_PORT=6379

# ── E-mail (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=sua_senha_smtp

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PAYMENT_GATEWAY=mercadopago
# URL pública do webhook — use a URL do seu Railway:
MP_WEBHOOK_URL=https://SEU_BACKEND.up.railway.app/api/subscriptions/mp-webhook

# ── Groq AI ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_STRONG=llama-3.3-70b-versatile

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Provider: evolution | meta
WHATSAPP_PROVIDER=evolution

# Evolution API
EVOLUTION_API_URL=https://sua-evolution.seuservidor.com
EVOLUTION_API_KEY=sua_chave_evolution_aqui
EVOLUTION_INSTANCE=nome_da_instancia

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# ── CORS ─────────────────────────────────────────────────────────────────────
# URL do seu frontend no Netlify (ex: https://mafelorganizer.netlify.app)
CORS_ORIGIN=https://SEU_SITE.netlify.app


# Groq AI
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_STRONG=llama-3.3-70b-versatile

# ── WhatsApp ───────────────────────────────────────────────────
# Provider: evolution | meta
WHATSAPP_PROVIDER=evolution

# Evolution API (auto-hospedada) — https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=https://sua-evolution.seuservidor.com
EVOLUTION_API_KEY=sua_chave_evolution_aqui
EVOLUTION_INSTANCE=nome_da_instancia

# WhatsApp Cloud API (Meta oficial) — https://developers.facebook.com/docs/whatsapp
# Preencha aqui se usar WHATSAPP_PROVIDER=meta
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# Frontend origin
CORS_ORIGIN=http://localhost:4200
