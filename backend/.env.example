# Ambiente
NODE_ENV=development
PORT=3000

# Banco de dados PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=mafel_organizer
DB_USER=postgres
DB_PASS=sua_senha_aqui
DB_SSL=false

# JWT
JWT_SECRET=troque_por_segredo_forte_aqui
JWT_EXPIRATION=8h

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# E-mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=sua_senha_smtp

# PSP (ex.: Stripe)
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Mercado Pago
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PAYMENT_GATEWAY=mercadopago
# URL pública do webhook (use ngrok em dev): https://seudominio.com/api/subscriptions/mp-webhook
MP_WEBHOOK_URL=https://seudominio.com/api/subscriptions/mp-webhook

# Groq AI
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_STRONG=llama-3.3-70b-versatile

# ── WhatsApp ───────────────────────────────────────────────────
# Provider: evolution | meta
WHATSAPP_PROVIDER=evolution

# Evolution API (auto-hospedada) — https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=https://sua-evolution.seuservidor.com
EVOLUTION_API_KEY=sua_chave_evolution_aqui
EVOLUTION_INSTANCE=nome_da_instancia

# WhatsApp Cloud API (Meta oficial) — https://developers.facebook.com/docs/whatsapp
# Preencha aqui se usar WHATSAPP_PROVIDER=meta
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# Frontend origin
CORS_ORIGIN=http://localhost:4200
